{
    "manifest_version": 3,
    "name": "YouTube Shorts Blocker",
    "description": "Bloqueia e oculta vídeos Shorts no YouTube.",
    "version": "1.0.0",
    "permissions": [
        "scripting",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "*://*.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "YouTube Shorts Blocker",
        "default_popup": "popup.html",
        "default_icons": {
            "16": "icons/icon-16.svg",
            "48": "icons/icon-48.svg",
            "128": "icons/icon-128.svg"
        }
    },
    "icons": {
        "16": "icons/icon-16.svg",
        "48": "icons/icon-48.svg",
        "128": "icons/icon-128.svg"
    }
}