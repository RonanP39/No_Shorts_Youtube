{
    "manifest_version": 3,
    "name": "YouTube Shorts Blocker",
    "description": "Bloqueia e oculta vídeos Shorts no YouTube.",
    "version": "1.0.0",
    "permissions": [
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "*://*.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "YouTube Shorts Blocker"
    }
}